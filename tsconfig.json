{
  "compilerOptions": {

    "target": "es2022",

    "module": "ESNext",
    "rootDir": "./",                               
    "moduleResolution":"node", 
    "ignoreDeprecations": "6.0",

    "outDir": "./output",                                  
    "esModuleInterop": true,                            
    "forceConsistentCasingInFileNames": true,           

    "strict": true,                                     

    "skipLibCheck": true                                
  },
  "include": ["src/**/*", "./mongodb.ts"]
}
